<clickhouse>
    <profiles>
        <default>
            <!-- spill GROUP BY to disk when exceeding 2 GiB -->
            <max_bytes_before_external_group_by>2147483648</max_bytes_before_external_group_by>
            <!-- spill ORDER BY to disk when exceeding 2 GiB -->
            <max_bytes_before_external_sort>2147483648</max_bytes_before_external_sort>
            <!-- use all available cores for queries -->
            <max_threads>0</max_threads>
            <!-- compile expressions for repeated queries -->
            <compile_expressions>1</compile_expressions>
            <!-- mark cache for faster index lookups -->
            <use_uncompressed_cache>1</use_uncompressed_cache>
        </default>
    </profiles>
</clickhouse>
