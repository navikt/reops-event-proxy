{
  "index_patterns": ["events*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "event": {
          "properties": {
            "websiteId": {
              "type": "keyword"
            },
            "sessionId": {
              "type": "keyword"
            },
            "createdAt": {
              "type": "date"
            },
            "websiteEvent": {
              "properties": {
                "eventId": {
                  "type": "keyword"
                },
                "urlPath": {
                  "type": "keyword"
                },
                "urlQuery": {
                  "type": "text"
                },
                "referrerPath": {
                  "type": "keyword"
                },
                "referrerQuery": {
                  "type": "text"
                },
                "referrerDomain": {
                  "type": "keyword"
                },
                "pageTitle": {
                  "type": "text",
                  "fields": {
                    "keyword": {
                      "type": "keyword",
                      "ignore_above": 256
                    }
                  }
                },
                "eventType": {
                  "type": "integer"
                },
                "eventName": {
                  "type": "keyword"
                },
                "visitId": {
                  "type": "keyword"
                },
                "hostname": {
                  "type": "keyword"
                },
                "eventData": {
                  "type": "nested",
                  "properties": {
                    "eventDataId": {
                      "type": "keyword"
                    },
                    "dataKey": {
                      "type": "keyword"
                    },
                    "stringValue": {
                      "type": "text",
                      "fields": {
                        "keyword": {
                          "type": "keyword",
                          "ignore_above": 256
                        }
                      }
                    },
                    "numberValue": {
                      "type": "double"
                    },
                    "dateValue": {
                      "type": "date"
                    },
                    "dataType": {
                      "type": "integer"
                    }
                  }
                }
              }
            },
            "session": {
              "properties": {
                "browser": {
                  "type": "keyword"
                },
                "os": {
                  "type": "keyword"
                },
                "device": {
                  "type": "keyword"
                },
                "screen": {
                  "type": "keyword"
                },
                "language": {
                  "type": "keyword"
                },
                "country": {
                  "type": "keyword"
                },
                "distinctId": {
                  "type": "keyword"
                },
                "sessionData": {
                  "type": "nested",
                  "properties": {
                    "sessionDataId": {
                      "type": "keyword"
                    },
                    "sessionId": {
                      "type": "keyword"
                    },
                    "dataKey": {
                      "type": "keyword"
                    },
                    "stringValue": {
                      "type": "text",
                      "fields": {
                        "keyword": {
                          "type": "keyword",
                          "ignore_above": 256
                        }
                      }
                    },
                    "numberValue": {
                      "type": "double"
                    },
                    "dateValue": {
                      "type": "date"
                    },
                    "dataType": {
                      "type": "integer"
                    },
                    "distinctId": {
                      "type": "keyword"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
